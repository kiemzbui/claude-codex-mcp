{
  "name": "claude-codex-mcp",
  "description": "Routes Codex tasks via local MCP server with session-bound wake-up.",
  "version": "0.3.1",
  "keywords": ["codex", "mcp", "wake"],
  "mcpServers": {
    "claude-codex-mcp": {
      "command": "dotnet",
      "args": [
        "run",
