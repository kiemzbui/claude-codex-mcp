{
  "manager": {
    "stateDirectory": ".codex-manager",
    "logging": {
      "enableFileLogging": true,
      "filePath": "logs/server.log",
      "minimumLevel": "Information"
    },
    "profiles": {
      "test": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions.",
        "backend": "appServer",
        "readOnly": false,
        "permissions": {
          "sandbox": "workspace-write",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "direct",
        "allowedWorkflows": ["direct"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      },
      "implementation": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions.",
        "backend": "appServer",
        "readOnly": false,
        "permissions": {
          "sandbox": "workspace-write",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "direct",
        "allowedWorkflows": ["direct", "subagent_manager"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      },
      "investigation": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions. Do not edit files.",
        "backend": "appServer",
        "readOnly": true,
        "permissions": {
          "sandbox": "read-only",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "direct",
        "allowedWorkflows": ["direct", "subagent_manager"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      },
      "planning": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions.",
        "backend": "appServer",
        "readOnly": false,
        "permissions": {
          "sandbox": "workspace-write",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "prepare_orchestrate_plan",
        "allowedWorkflows": ["prepare_orchestrate_plan", "managed_plan"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      },
      "orchestration": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions.",
        "backend": "appServer",
        "readOnly": false,
        "permissions": {
          "sandbox": "workspace-write",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "orchestrate_execute",
        "allowedWorkflows": ["orchestrate_execute", "orchestrate_revise"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      },
      "review": {
        "repo": "*",
        "allowedRepos": ["*"],
        "taskPrefix": "Use the repository instructions. Do not edit files.",
        "backend": "appServer",
        "readOnly": true,
        "permissions": {
          "sandbox": "read-only",
          "approvalPolicy": "never"
        },
        "defaultWorkflow": "direct",
        "allowedWorkflows": ["direct", "subagent_manager"],
        "maxConcurrentJobs": 1,
        "channelNotifications": { "enabled": true },
        "defaultModel": "gpt-5.4",
        "defaultEffort": "high",
        "fastMode": true
      }
    }
  }
}
